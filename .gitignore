output/final/**
working/**
*.mp4
*.mov
*.mkv
*.avi
*.webm
*.wav
*.mp3
*.m4a

# 但保留資料夾結構
!raw/.gitkeep
!output/final/.gitkeep
!working/.gitkeep

# 中間字幕檔（依需求可移除這條）
